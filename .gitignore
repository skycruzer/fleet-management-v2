node_modules
node_modules_broken_*
node_modules_old

# Next.js
.next/
out/

# Build outputs
storybook-static/
tsconfig.tsbuildinfo
next-env.d.ts

# Test outputs
test-results/
playwright-report/
test-screenshots/
screenshots/

# Backups
*.backup
node_modules_old/

# Environment files — broad pattern so stray duplicates (e.g. ".env.production 2.local"
# from a vercel env pull) can never be committed; whitelist examples explicitly
.env*
!.env.example
!.env.test.local.example

# Vercel
.vercel/

# Debug logs
firebase-debug.log

# Supabase CLI scratch state (per-machine, churns on CLI version changes)
supabase/.temp/

# Local assistant journal/notes — never project source
knowledge/

# IDE / tooling
.worktrees/
.playwright-mcp/
.kombai/
.serena/

# Claude Code session artifacts
.claude/worktrees/
.claude/scheduled_tasks.lock
.vercel

# EBT migration working files (raw pg_dump scratch — data is captured in supabase/migrations/)
scratch/

# Cloud-sync conflict copies. The repo lives in a synced folder, which spawns
# "<name> 2.ext" duplicates (18 of these had been committed, plus copies under
# .git/ that silently break fetch). Keep them out of the index; clean the ones
# under .git/refs/ by hand if origin/* ever looks stale.
*[ ][0-9].*
*[ ][0-9][0-9].*
